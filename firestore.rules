rules_version = '2';

// Firestore security rules — everything is scoped under the user's own doc.
// Deploy with:  firebase deploy --only firestore:rules
// (or paste into Firebase Console → Firestore → Rules)
service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own record (userId, name, email, createdAt) + their plan fields
    // and their videos subcollection. Only the owner can read/write.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /videos/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Everything else denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
